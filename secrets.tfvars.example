# Secrets (provide via -var-file=secret.tfvars or enable 1Password)
# This file should be in .gitignore

hcloud_token              = "hcloud_xxx"
cloudflare_api_token      = "cf_xxx"
tailscale_oauth_secret    = "ts_xxx"
tailscale_oauth_client_id = "ts_client_xxx"

# GCP credentials are optional - omit to use gcloud CLI ADC
# gcp_credentials         = "{\"type\":\"service_account\",...}"

# Optional: Enable 1Password instead
# enable_onepassword   = true
# onepassword_account  = "your-account.1password.com"
# onepassword_vault    = "Infrastructure"
